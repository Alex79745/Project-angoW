4️⃣ templates/configmap.yaml
apiVersion: v1
kind: ConfigMap
metadata:
  name: {{ include "hub-runner.fullname" . }}
  namespace: {{ .Release.Namespace }}
data:
  hub-dataplane.yaml: |
    type: Dataplane
    mesh: {{ .Values.mesh }}
    name: {{ .Values.dataplane.name }}
    networking:
      address: "0.0.0.0"
      inbound:
{{- range .Values.dataplane.inbound }}
        - port: {{ .port }}
          servicePort: {{ .port }}
          tags:
            service: {{ .service }}
{{- end }}
      outbound:
{{- range .Values.dataplane.outbound }}
        - port: {{ .port }}
          service: {{ .service }}
{{- end }}
5️⃣ templates/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ include "hub-runner.fullname" . }}
  namespace: {{ .Release.Namespace }}
spec:
  replicas: {{ .Values.replicaCount }}
  selector:
    matchLabels:
      app: {{ include "hub-runner.name" . }}
  template:
    metadata:
      labels:
        app: {{ include "hub-runner.name" . }}
    spec:
      containers:
        - name: hub-runner
          image: "{{ .Values.image.repository }}:{{ .Values.image.tag }}"
          imagePullPolicy: {{ .Values.image.pullPolicy }}
          args:
            - "run"
            - "--cp-address={{ .Values.controlPlane.address }}"
            - "--dataplane-file=/etc/kuma/hub-dataplane.yaml"
          volumeMounts:
