apiVersion: apps/v1
kind: Deployment
metadata:
  name: hub-runner
  namespace: kuma-system
spec:
  replicas: 1
  selector:
    matchLabels:
      app: hub-runner
  template:
    metadata:
      labels:
        app: hub-runner
    spec:
      containers:
        - name: hub-runner
          image: kuma/kuma-dp:2.5.1 # match your CP version
          args:
            - "run"
            - "--cp-address=http://kuma-control-plane.kuma-system.svc:5681"
            - "--dataplane-file=/etc/kuma/hub-dataplane.yaml"
          volumeMounts:
            - name: dp-config
              mountPath: /etc/kuma
      volumes:
        - name: dp-config
          configMap:
            name: hub-dataplane
